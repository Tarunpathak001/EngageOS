# PostgreSQL Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/xeno_crm?schema=public"

# Redis Server URL (Used by BullMQ for queues and workers)
REDIS_URL="redis://localhost:6379"

# Port mapping for Backend API Server
PORT=5000
NODE_ENV="development"

# Google Gemini API Key (Required for AI Campaign generation & recommendations)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# SMTP Authentication configuration for Gmail
EMAIL_USER="your_gmail_username@gmail.com"
EMAIL_PASS="your_gmail_app_password"

# Telegram Bot API Token for Customer Account Onboarding
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"
TELEGRAM_POLLING="true" # Set to true to start polling updates locally

# Channel Service microservice endpoint URL
CHANNEL_SERVICE_URL="http://localhost:6000"

# JSON Web Token Secret (For secure cookies and session tokens)
JWT_SECRET="your_jwt_secret_token_here"
